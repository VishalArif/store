// Prisma schema for Store (auth + app)
// Run: npx prisma generate && npx prisma db push (or migrate)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  price          Int
  compareAtPrice Int?
  image          String
  imageAlt       String
  onSale         Boolean  @default(false)
  description    String?
  images         Json?    // array of image URLs
  colors         Json?    // array of { name, hex }
  connection     Json?    // array of strings
  featured       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
